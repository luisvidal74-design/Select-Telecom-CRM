{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user (Admin, Support, Seller)",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "profilePic": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "isAdmin": { "type": "integer" }
      },
      "required": ["firstName", "lastName", "email", "role"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Company customer",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "orgNumber": { "type": "string" },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "zipCode": { "type": "string" },
        "contactPerson": { "type": "string" },
        "contactPhone": { "type": "string" },
        "responsibleSeller": { "type": "string" },
        "website": { "type": "string" },
        "services": { "type": "string" }
      },
      "required": ["name", "orgNumber"]
    },
    "CustomerUser": {
      "title": "CustomerUser",
      "description": "User belonging to a customer",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "role": { "type": "string" },
        "office": { "type": "string" },
        "isAuthorizedBuyer": { "type": "integer" }
      },
      "required": ["firstName", "lastName", "email"]
    },
    "Brand": {
      "title": "Brand",
      "description": "Equipment brand",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Equipment": {
      "title": "Equipment",
      "description": "Customer equipment (mobile phones, etc.)",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "color": { "type": "string" },
        "memory": { "type": "string" },
        "imei": { "type": "string" },
        "purchasePlace": { "type": "string" },
        "orderNumber": { "type": "string" },
        "purchaseDate": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "customerPrice": { "type": "number" },
        "sellerId": { "type": "integer" }
      },
      "required": ["brand", "model", "imei"]
    },
    "SelectCare": {
      "title": "SelectCare",
      "description": "Select Care subscription for equipment",
      "type": "object",
      "properties": {
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "color": { "type": "string" },
        "memory": { "type": "string" },
        "imei": { "type": "string" },
        "purchasePlace": { "type": "string" },
        "orderNumber": { "type": "string" },
        "purchaseDate": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "monthlyFee": { "type": "number" },
        "userId": { "type": "integer" },
        "contractPeriod": { "type": "integer" },
        "endDate": { "type": "string" },
        "siemensContractNumber": { "type": "string" },
        "sellerId": { "type": "integer" },
        "status": { "type": "string", "enum": ["Aktiv", "Under reparation"] }
      },
      "required": ["brand", "model", "imei", "monthlyFee"]
    },
    "News": {
      "title": "News",
      "description": "Company news/announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "authorId": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId"]
    },
    "DrivingLog": {
      "title": "DrivingLog",
      "description": "Customer driving log entry",
      "type": "object",
      "properties": {
        "regNo": { "type": "string" },
        "driverName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "deviceType": { "type": "string" },
        "schema": { "type": "string" },
        "monthlyFee": { "type": "number" },
        "sellerId": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["regNo", "driverName", "email"]
    },
    "Contract": {
      "title": "Contract",
      "description": "Customer contract",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "startDate": { "type": "string" },
        "contractPeriod": { "type": "integer" },
        "endDate": { "type": "string" },
        "sellerId": { "type": "integer" },
        "customFields": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "startDate", "contractPeriod"]
    },
    "ContractFile": {
      "title": "ContractFile",
      "description": "File attached to a contract",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mimeType": { "type": "string" },
        "data": { "type": "string" },
        "size": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "mimeType", "data"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "Calendar event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "sellerId": { "type": "integer" },
        "type": { "type": "string" },
        "relatedId": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startDate", "endDate", "sellerId"]
    },
    "SelectCareLog": {
      "title": "SelectCareLog",
      "description": "Log entry for Select Care status changes",
      "type": "object",
      "properties": {
        "userId": { "type": "integer" },
        "fromStatus": { "type": "string" },
        "toStatus": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["fromStatus", "toStatus", "timestamp"]
    },
    "SupportTicket": {
      "title": "SupportTicket",
      "description": "Support ticket",
      "type": "object",
      "properties": {
        "ticketNumber": { "type": "string" },
        "customerId": { "type": "integer" },
        "selectCareId": { "type": "integer" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Registrerad", "Väntar", "Skickat för reparation", "Under reparation", "Avslutad"] },
        "priority": { "type": "string", "enum": ["Låg", "Normal", "Hög", "Kritisk"] },
        "createdBy": { "type": "integer" },
        "assignedTo": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["ticketNumber", "title", "status", "priority", "createdBy"]
    },
    "SupportTicketLog": {
      "title": "SupportTicketLog",
      "description": "Log entry for support ticket actions",
      "type": "object",
      "properties": {
        "userId": { "type": "integer" },
        "action": { "type": "string" },
        "note": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "action", "timestamp"]
    },
    "SelectCareHistory": {
      "title": "SelectCareHistory",
      "description": "History of deleted Select Care subscriptions",
      "type": "object",
      "properties": {
        "originalId": { "type": "integer" },
        "customerId": { "type": "integer" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "color": { "type": "string" },
        "memory": { "type": "string" },
        "imei": { "type": "string" },
        "purchasePlace": { "type": "string" },
        "orderNumber": { "type": "string" },
        "purchaseDate": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "monthlyFee": { "type": "number" },
        "userId": { "type": "integer" },
        "contractPeriod": { "type": "integer" },
        "endDate": { "type": "string" },
        "siemensContractNumber": { "type": "string" },
        "deletedAt": { "type": "string", "format": "date-time" },
        "deletedBy": { "type": "string" },
        "sellerId": { "type": "integer" }
      },
      "required": ["originalId", "customerId", "brand", "model", "imei", "deletedAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "System users"
    },
    "customers": {
      "schema": "Customer",
      "description": "Customer companies"
    },
    "customers/{customerId}/users": {
      "schema": "CustomerUser",
      "description": "Users belonging to a specific customer"
    },
    "brands": {
      "schema": "Brand",
      "description": "Equipment brands"
    },
    "customers/{customerId}/equipment": {
      "schema": "Equipment",
      "description": "Equipment belonging to a customer"
    },
    "customers/{customerId}/selectCare": {
      "schema": "SelectCare",
      "description": "Select Care subscriptions for a customer"
    },
    "news": {
      "schema": "News",
      "description": "Company news"
    },
    "customers/{customerId}/drivingLogs": {
      "schema": "DrivingLog",
      "description": "Driving logs for a customer"
    },
    "customers/{customerId}/contracts": {
      "schema": "Contract",
      "description": "Contracts for a customer"
    },
    "contracts/{contractId}/files": {
      "schema": "ContractFile",
      "description": "Files attached to a contract"
    },
    "calendarEvents": {
      "schema": "CalendarEvent",
      "description": "Calendar events"
    },
    "selectCare/{selectCareId}/logs": {
      "schema": "SelectCareLog",
      "description": "Logs for a Select Care subscription"
    },
    "supportTickets": {
      "schema": "SupportTicket",
      "description": "Support tickets"
    },
    "supportTickets/{ticketId}/logs": {
      "schema": "SupportTicketLog",
      "description": "Logs for a support ticket"
    },
    "selectCareHistory": {
      "schema": "SelectCareHistory",
      "description": "History of deleted Select Care subscriptions"
    }
  }
}
